{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "cssPriority": "user",
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 8,
  "control-center-margin-left": 0,
  "notification-2fa-action": true,
  "notification-inline-replies": true,
  "notification-icon-size": 48,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "notification-window-width": 380,
  "timeout": 6,
  "timeout-low": 3,
  "timeout-critical": 0,
  "fit-to-screen": false,
  "control-center-width": 460,
  "control-center-height": 750,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 250,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,
  "widgets": [
    "buttons-grid",
    "mpris",
    "volume",
    "backlight",
    "dnd",
    "title",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "󰂚 Notifications",
      "clear-all-button": true,
      "button-text": "󰎟 Clear All"
    },
    "dnd": {
      "text": "󰂛 Do Not Disturb"
    },
    "mpris": {
      "image-size": 80,
      "image-radius": 12
    },
    "volume": {
      "label": "󰕾",
      "show-per-app": true
    },
    "backlight": {
      "label": "󰃟"
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "󰐥",
          "command": "wlogout"
        },
        {
          "label": "󰌾",
          "command": "hyprlock"
        },
        {
          "label": "󰍃",
          "command": "hyprctl eval 'hl.dsp.exit()'"
        },
        {
          "label": "󰤨",
          "command": "kitty -e nmtui"
        },
        {
          "label": "󰝟",
          "command": "wpctl set-mute @DEFAULT_SINK@ toggle"
        },
        {
          "label": "󰂯",
          "command": "blueman-manager"
        },
        {
          "label": "󰌌",
          "command": "bash -c 'hyprctl eval \"hl.config({ input = { kb_layout = (hyprctl getoption input:kb_layout | grep str | awk \"{print \\$2}\") == '\\''us'\\'' and '\\''in'\\'' or '\\''us'\\'' } })\"'"
        },
        {
          "label": "󰎈",
          "command": "bash ~/hyprland_backup/scripts/animation-switcher.sh"
        },
        {
          "label": "󰕰",
          "command": "bash ~/hyprland_backup/scripts/layout_switcher.sh"
        },
        {
          "label": "󰖄",
          "command": "bash ~/hyprland_backup/scripts/wallpaper-switcher.sh"
        },
        {
          "label": "󰏘",
          "command": "bash ~/hyprland_backup/scripts/theme-switcher.sh"
        },
        {
          "label": "󰍹",
          "command": "hyprctl eval 'hl.config({ decoration = { blur = { enabled = not hl.get_config().decoration.blur.enabled } } })'"
        }
      ]
    }
  }
}
