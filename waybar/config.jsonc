{
"layer": "top",
"position": "top",
"height": 44,
"margin-left": 4,
"margin-right": 4,
"margin-top": 2,
"margin-bottom": 0,
"exclusive": true,
"passthrough": false,
"gtk-layer-shell": true,
"reload_style_on_change": true,

"modules-left": [
    "custom/launch",
    "mpris",
    "hyprland/window"
],
"modules-center": [
    "custom/cava-left",
    "hyprland/workspaces",
    "custom/cava-right"
],
"modules-right": [
    "tray",
    "group/right-side"
],

"group/hardware": {
    "orientation": "horizontal",
    "drawer": {
        "transition-duration": 300,
        "children-class": "hardware-drawer",
        "transition-left-to-right": false
    },
    "modules": [
        "custom/system",
        "cpu",
        "temperature",
        "memory",
        "disk",
        "power-profiles-daemon"
    ]
},

"group/right-side": {
    "orientation": "horizontal",
    "modules": [
        "network",
        "bluetooth",
        "backlight",
        "pulseaudio",
        "battery",
        "custom/weather",
        "clock",
        "custom/notification",
        "custom/power"
    ]
},

"custom/launch": {
    "format": "َ°£‡",
    "on-click": "rofi -show drun",
    "tooltip": true,
    "tooltip-format": "Applications Menu"
},

"custom/system": {
    "format": "َ°†§",
    "tooltip": true,
    "tooltip-format": "Hardware Stats (Click to toggle)"
},

"custom/cava-left": {
    "exec": "~/.config/waybar/cava.sh left",
    "format": "{}",
    "tooltip": false,
    "restart-interval": 2
},

"custom/cava-right": {
    "exec": "~/.config/waybar/cava.sh right",
    "format": "{}",
    "tooltip": false,
    "restart-interval": 2
},

"custom/updates": {
    "format": "َ°ڈ” {}",
    "interval": 3600,
    "exec": "checkupdates 2>/dev/null | wc -l || echo 0",
    "on-click": "kitty -e sudo pacman -Syu",
    "tooltip": true,
    "tooltip-format": "{} Pending Updates"
},

"hyprland/window": {
    "format": "{class}",
    "max-length": 30,
    "rewrite": {
        "firefox": "َ°ˆ¹ Firefox",
        "brave-browser": "َ°–ں Brave",
        "code-oss": "َ°¨‍ VS Code",
        "kitty": "َ°„› Terminal",
        "dolphin": "َ°‰‹ Files",
        "spotify": "َ°“‡ Spotify",
        "vesktop": "َ°™¯ Discord",
        "obsidian": "َ°‹© Obsidian",
        "org.telegram.desktop": "َ°چ، Telegram",
        "zen-browser": "َ°–ں Zen",
        "": "َ°‡„ Desktop"
    },
    "separate-outputs": true,
    "tooltip": true,
    "tooltip-format": "{title}"
},

"hyprland/workspaces": {
    "active-only": false,
    "all-outputs": true,
    "format": "{icon}",
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "persistent-workspaces": {
        "1": [], "2": [], "3": [], "4": [], "5": []
    },
    "format-icons": {
        "active": "َ°®¯",
        "default": "َ°ٹ ",
        "urgent": "َ°€¨",
        "empty": "َ°‘ٹ"
    },
    "tooltip": true,
    "tooltip-format": "Workspace {name}"
},

"tray": {
    "icon-size": 18,
    "spacing": 10,
    "show-passive-items": true
},

"mpris": {
    "interval": 10,
    "format": "{player_icon} {dynamic}",
    "format-paused": "{status_icon} <i>{dynamic}</i>",
    "on-click-middle": "playerctl play-pause",
    "on-click": "playerctl previous",
    "on-click-right": "playerctl next",
    "scroll-step": 5.0,
    "on-scroll-up": "$HOME/.config/hypr/scripts/Volume.sh --inc",
    "on-scroll-down": "$HOME/.config/hypr/scripts/Volume.sh --dec",
    "smooth-scrolling-threshold": 1,
    "player-icons": {
        "chromium": "ï‰¨",
        "default": "ï€‌",
        "firefox": "ï‰©",
        "kdeconnect": "ïکں",
        "mopidy": "ï€پ",
        "mpv": "َ°گ¹",
        "spotify": "ï†¼",
        "vlc": "َ°•¼"
    },
    "status-icons": {
        "paused": "َ°گژ",
        "playing": "ïپ‹",
        "stopped": "ïپچ"
    },
    "max-length": 30
},

"cpu": {
    "interval": 2,
    "format": "َ°»  {usage}%",
    "tooltip": true,
    "tooltip-format": "CPU: {usage}%\nLoad: {load}",
    "on-click": "kitty --hold -e bash -c 'LANG=en_US.UTF-8 btop'"
},

"memory": {
    "interval": 3,
    "format": "َ°چ› {percentage}%",
    "format-alt": "َ°چ› {used:0.1f}G",
    "tooltip": true,
    "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G ({percentage}%)\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
    "on-click": "kitty --hold -e bash -c 'LANG=en_US.UTF-8 btop'"
},

"temperature": {
    "thermal-zone": 26,
    "interval": 3,
    "format": "َ°”ڈ {temperatureC}آ°C",
    "format-critical": "َ°¸پ {temperatureC}آ°C",
    "critical-threshold": 85,
    "tooltip": true,
    "tooltip-format": "CPU Temp: {temperatureC}آ°C",
    "on-click": "kitty --hold -e bash -c 'LANG=en_US.UTF-8 btop'"
},

"network": {
    "interval": 2,
    "format-wifi": "{icon}",
    "format-ethernet": "َ°ˆ€ {ifname}",
    "format-disconnected": "َ°¤­",
    "format-icons": [
        "َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"
    ],
    "format-alt": "{icon} ï„¹ {bandwidthUpBytes} ï„؛ {bandwidthDownBytes}",
    "on-click-right": "kitty -e nmtui",
    "tooltip": true,
    "tooltip-format": "َ°¤¨ {essid} ({signalStrength}%)\nَ°©ں {ipaddr}/{cidr}\nَ°•’ Up: {bandwidthUpBytes}\nَ°‡ڑ Down: {bandwidthDownBytes}\nَ°›¶ Gateway: {gwaddr}"
},

"bluetooth": {
    "format": "َ°‚¯",
    "format-disabled": "َ°‚²",
    "format-connected": "َ°‚±",
    "format-connected-battery": "َ°‚± {device_alias} {device_battery_percentage}%",
    "format-alt": "َ°‚± {device_battery_percentage}%",
    "on-click": "",
    "on-click-right": "blueman-manager",
    "on-click-middle": "bluetoothctl power toggle",
    "tooltip": true,
    "tooltip-format": "{controller_alias}\n{num_connections} connected\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "  {device_alias} {device_battery_percentage}%"
},

"custom/weather": {
    "format": "{}",
    "return-type": "json",
    "interval": 1800,
    "exec": "$HOME/.config/waybar/weather.sh",
    "on-click": "kitty --hold -e curl -s 'https://wttr.in/Greater+Noida'"
},

"power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
        "default": "َ°¾†",
        "performance": "َ°“…",
        "balanced": "َ°¾†",
        "power-saver": "َ°¾‡"
    }
},

"backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
        "îڈ•", "îڈ–", "îڈ—", "îڈک", "îڈ™", "îڈڑ", "îڈ›", "îڈœ", "îڈ‌", "îڈ‍", "îڈں", "îڈ ", "îڈ،", "îڈ¢", "îڈ£"
    ],
    "format-alt": "{icon}",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "brightnessctl s 5%+",
    "on-scroll-down": "brightnessctl s 5%-",
    "smooth-scrolling-threshold": 1,
    "tooltip": true,
    "tooltip-format": "Brightness: {percent}%"
},

"pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°–پ Muted",
    "format-alt": "{icon}",
    "format-icons": {
        "headphone": "ï€¥",
        "hands-free": "ï€¥",
        "headset": "ï–گ",
        "phone": "ï‚•",
        "portable": "ï‚•",
        "car": "ï†¹",
        "default": [
            "ï€¦", "ï€§", "َ°•¾",  "ï€¨"
        ],
        "ignored-sinks": [
            "Easy Effects Sink"
        ]
    },
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "pavucontrol",
    "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
    "scroll-step": 5,
    "tooltip": true,
    "tooltip-format": "َ°•¾ {desc}\n{volume}%"
},

"disk": {
    "interval": 30,
    "format": "َ°‹ٹ {percentage_used}%",
    "format-alt": "َ°‹ٹ",
    "path": "/",
    "tooltip": true,
    "tooltip-format": "َ°‹ٹ {path}\nUsed: {used} / {total}\nFree: {free} ({percentage_free}%)"
},

"battery": {
    "states": { "good": 80, "warning": 30, "critical": 15 },
    "format": "{icon} {capacity}%",
    "format-charging": "ïƒ§ {capacity}%",
    "format-plugged": "َ±ک– {capacity}%",
    "format-full": "{icon} Full",
    "format-alt": "{icon} {time}",
    "format-icons": [
        "َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"
    ],
    "format-time": "{H}h {M}min",
    "tooltip": true,
    "tooltip-format": "{capacity}% â€” {timeTo}\nPower: {power}W"
},

"clock": {
    "interval": 1,
    "format": "ï€— {:%I:%M %p}", 
    "format-alt": "ï€— {:%I:%M %p  ïپ³ %Y, %d %B, %A}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
        "mode": "year",
        "mode-mon-col": 3,
        "weeks-pos": "right",
        "on-scroll": 1,
        "format": {
            "months": "<span color='#ffead3'><b>{}</b></span>",
            "days": "<span color='#ecc6d9'><b>{}</b></span>",
            "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
            "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
            "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
        }
    }
},

"custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
        "notification": "<span foreground='#f38ba8'>َ±…«</span>",
        "none": "َ°‚ڑ",
        "dnd-notification": "<span foreground='#f38ba8'>َ±ڈ§</span>",
        "dnd-none": "َ±ڈ§",
        "inhibited-notification": "<span foreground='#f38ba8'>َ±…«</span>",
        "inhibited-none": "َ°‚ڑ",
        "dnd-inhibited-notification": "<span foreground='#f38ba8'>َ±ڈ§</span>",
        "dnd-inhibited-none": "َ±ڈ§"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
},

"custom/power": {
    "format": "âڈ»",
    "on-click": "wlogout",
    "tooltip": true,
    "tooltip-format": "Power Menu"
}

}